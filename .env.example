# Copy to .env and fill in values. Never commit .env.
# Client (Vite): VITE_* is embedded in the browser bundle — use only the Supabase anon (publishable) key, never the service_role key.

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase Edge Functions (configure in Supabase Dashboard → Edge Functions → Secrets, or `supabase secrets set` — do NOT put these in VITE_* or commit them)
# SUPABASE_SERVICE_ROLE_KEY=
# PAYSTACK_SECRET_KEY=
# LOVABLE_API_KEY=
# ETHERSCAN_API_KEY=
# ALCHEMY_API_KEY=
# MORALIS_API_KEY=
# DUNE_API_KEY=
# NANSEN_API_KEY=
